# === Trackly API ===
KANBAN_PROJECT_URL=https://trackly-api.azurewebsites.net

# Auth mode: bearer | password-login | apikey-login
TRACKLY_AUTH_MODE=apikey-login
TRACKLY_EMAIL=you@example.com

# Bearer auth (TRACKLY_AUTH_MODE=bearer)
KANBAN_TOKEN=

# Password auth (TRACKLY_AUTH_MODE=password-login)
TRACKLY_PASSWORD=

# API key auth (TRACKLY_AUTH_MODE=apikey-login)
TRACKLY_API_KEY=

# Optional: default project/workspace
TRACKLY_PROJECT_ID=
TRACKLY_WORKSPACE_ID=

# Optional: request tuning
# TRACKLY_RATE_LIMIT_MS=0
# TRACKLY_MAX_RETRIES=3
# TRACKLY_TIMEOUT_MS=30000

# === MCP Server ===

# Auth mode for MCP connections: apikey | oauth
MCP_AUTH_MODE=apikey

# API key for MCP_AUTH_MODE=apikey (leave empty to allow unauthenticated access)
MCP_API_KEY=

# HTTP port (set to enable HTTP mode; unset or 0 for stdio)
MCP_HTTP_PORT=3000

# Azure Entra ID (required when MCP_AUTH_MODE=oauth)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Optional: restrict OAuth users to a specific domain (e.g. example.com)
MCP_ALLOWED_DOMAIN=

# Optional: external path prefix when behind a reverse proxy (e.g. /trackly-mcp)
MCP_EXTERNAL_PATH=

# Optional: CORS origin for browser-based MCP clients (default: *)
MCP_CORS_ORIGIN=*

# === Logging ===
LOG_LEVEL=info
