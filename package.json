{
  "name": "trackly-mcp",
  "version": "0.1.0",
  "description": "Trackly MCP server for projects, tasks, comments, and status management.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp-server": {
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.js"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "build:emit": "tsc -p tsconfig.build.json",
    "prepare": "npm run build:emit",
    "start": "node dist/mcp-server.js",
    "dev": "tsx src/mcp-server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
